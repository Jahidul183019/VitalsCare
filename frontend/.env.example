# Environment Variables for VitalsCare Frontend

# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this in your backend environment, not the frontend directly.
# The frontend communicates with the backend via the /api proxy.
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The base URL where this app is hosted.
# Used for self-referential links and API endpoints.
# Default for local development: http://localhost:5173
APP_URL="http://localhost:5173"
